-- ============================================
-- HELPER: Mark boss quest as hit when we start attacking it
-- ============================================
local function markBossQuestHit(quests, QuestInfo)
    if getgenv().bossQuestHitId then return end -- Already marked a boss for this cycle
    for _, q in pairs(quests) do
        local cfg = QuestInfo.ClanQuests[q.Id]
        if cfg and q.Amount < cfg.GoalAmount then
            local typeCfg = QuestInfo.QuestTypes[cfg.QuestType]
            if typeCfg then
                local ok, txt = pcall(function() return typeCfg.InfoText(q.Amount, cfg.GoalAmount, cfg) end)
                if ok and txt and tostring(txt):lower():find("boss") then
                    getgenv().bossQuestHitId = q.Id
                    getgenv().bossQuestHitTime = tick()
                    break
                end
            end
        end
    end
end


