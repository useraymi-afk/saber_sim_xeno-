function autoCompletePetdex()
    spawn(function()
        qprint("[PETDEX] Starting Auto Complete Petdex loop...")
        local failedBuys = {} -- Tracks eggs/pets that are inactive/event-only

        while getgenv().autoCompletePetdex and task do
            local success, err = pcall(function()
                -- 1. Teleport to Pet Shop
                local char = Players.LocalPlayer.Character
                if not char then return end
                local charRoot = char:FindFirstChild("HumanoidRootPart")
                local petShopLocation = workspace.Gameplay.Locations:FindFirstChild("PetShop")
                if charRoot and petShopLocation then
                    local dist = (charRoot.Position - petShopLocation.CFrame.Position).Magnitude
                    if dist > 10 then
                        charRoot.CFrame = petShopLocation.CFrame
                        task.wait(0.5)
                    end
                end

                -- 2. Get Data
                local dataManager = require(Players.LocalPlayer.PlayerScripts.MainClient.ClientDataManager)
                local petsInfo = require(ReplicatedStorage.Modules.PetsInfo)
                if not dataManager.Data or not dataManager.Data.Pets then return end

                -- 3. Count current pets & build owned list
                local ownedPetTypes = {}
                local prevPetCount = 0
                for uid, petData in pairs(dataManager.Data.Pets) do
                    prevPetCount += 1
                    if petData.Type then
                        ownedPetTypes[petData.Type] = true
                    end
                end

                -- 4. Find missing pets ONLY from active shop eggs
                local eggToBuy = nil
                local missingPetName = nil

                local shopEggs = getgenv().ActiveShopEggs

                if shopEggs and #shopEggs > 0 then
                    for _, eggInfo in ipairs(shopEggs) do
                        local eggName = eggInfo.Name

                        -- Skip eggs we already know are inactive/failed
                        if not failedBuys[eggName] then
                            local eggData = petsInfo.Eggs and petsInfo.Eggs[eggName]
                            if eggData and eggData.Odds then
                                for petName, chance in pairs(eggData.Odds) do
                                    -- Only try to get this pet if we don't have it AND haven't failed to get it before
                                    if not ownedPetTypes[petName] and not failedBuys[petName] then
                                        eggToBuy = eggName
                                        missingPetName = petName
                                        break
                                    end
                                end
                            end
                        end

                        if eggToBuy then break end
                    end
                end

                -- 5. Buy the egg if we found a missing pet
                if eggToBuy and missingPetName then
                    qprint("[PETDEX] Missing pet:", missingPetName, "-> Trying egg:", eggToBuy)
                    ReplicatedStorage.Events.UIAction:FireServer("BuyEgg", eggToBuy)
                    task.wait(3)

                    -- 6. Verify if the buy was successful
                    local newPetCount = 0
                    for _ in pairs(dataManager.Data.Pets) do newPetCount += 1 end

                    if newPetCount <= prevPetCount then
                        -- If we didn't get a new pet, the egg is likely inactive/event-only
                        qwarn("[PETDEX] Failed to buy/hatch", eggToBuy, "- Blacklisting pet:", missingPetName)
                        failedBuys[missingPetName] = true
                        failedBuys[eggName] = true -- Blacklist the whole egg too
                    else
                        qprint("[PETDEX] Successfully hatched! Re-scanning...")
                    end
                else
                    qprint("[PETDEX] No active missing pets found! Waiting 15s...")
                    task.wait(15)
                end
            end)

            if not success then
                qwarn("[PETDEX] Error:", err)
            end

            task.wait(1)
        end
    end)
end

function autoRedeemPetdexRewards()
