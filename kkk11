-- Убедись, что внутри неё ты заменил 'getgenv().autoQuestExecute' на 'getgenv().SaberConfig.AutoQuest'

function autoJoinDungeon()
    pcall(function()
        local dataManager = require(lp.PlayerScripts.MainClient.ClientDataManager)
        local timeManager = require(lp.PlayerScripts.MainClient.DateTimeManager)
        if timeManager:Now() >= (dataManager.Data.DungeonCooldownEndDT or 0) then
            ReplicatedStorage.Events.UIAction:FireServer("DungeonGroupAction", "Create", "Public", getgenv().SaberConfig.SelectedDungeon, getgenv().SaberConfig.SelectedDifficulty)
            task.wait(1.5)
            ReplicatedStorage.Events.UIAction:FireServer("DungeonGroupAction", "Start")
        end
    end)
end

