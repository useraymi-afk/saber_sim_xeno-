function autoJoinDungeon()
    task.spawn(function()
        while getgenv().SaberConfig.DungeonActive do
            pcall(function()
                local dungeonStorage = workspace:FindFirstChild("DungeonStorage")
                local isInDungeon = false
                if dungeonStorage then
                    for _, folder in pairs(dungeonStorage:GetChildren()) do
                        if #folder:GetChildren() > 0 then isInDungeon = true; break end
                    end
                end
                if not isInDungeon then
                    local dataManager = require(lp.PlayerScripts.MainClient.ClientDataManager)
                    local dateTimeManager = require(lp.PlayerScripts.MainClient.DateTimeManager)
                    if dateTimeManager:Now() >= (dataManager.Data.DungeonCooldownEndDT or 0) then
                        ReplicatedStorage.Events.UIAction:FireServer("DungeonGroupAction", "Create", "Public", getgenv().SaberConfig.SelectedDungeon, getgenv().SaberConfig.SelectedDifficulty)
                        task.wait(1.5)
                        ReplicatedStorage.Events.UIAction:FireServer("DungeonGroupAction", "Start")
                    end
                end
            end)
            task.wait(3)
        end
    end)
end

