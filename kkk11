function getBossData()
    local gameplay = workspace:FindFirstChild("Gameplay")
    local bossFolder = gameplay and gameplay:FindFirstChild("Boss")
    local holder = bossFolder and bossFolder:FindFirstChild("BossHolder")
    local model = holder and holder:FindFirstChildOfClass("Model")
    if not model then return nil end
    return model:FindFirstChild("HumanoidRootPart")
end

-- Хук на урон (Hit Spoof)
pcall(function()
    local HitDetection = require(lp.PlayerScripts.MainClient.ClientTool.HitDetection)
    if not getgenv().oldGetHits then getgenv().oldGetHits = HitDetection.GetBossesAndMobsHit end
    HitDetection.GetBossesAndMobsHit = function(self, player)
        if getgenv().SaberConfig.AutoQuest or getgenv().SaberConfig.DungeonActive then
            local hitAll = {}
            local seen = {}
            for _, tag in ipairs({"Boss", "EventBoss", "Mob", "DungeonEnemy"}) do
                for _, mob in ipairs(CollectionService:GetTagged(tag)) do
                    if mob and mob.Parent and not seen[mob] then
                        local hrp = mob:FindFirstChild("HumanoidRootPart")
                        if hrp and (mob:GetAttribute("Health") or 1) > 0 then
                            seen[mob] = true
                            table.insert(hitAll, mob)
                        end
                    end
                end
            end
            return hitAll
        end
        return getgenv().oldGetHits(self, player)
    end
end)

