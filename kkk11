local function forceLoadZones()
    pcall(function()
        local HiddenRegions = ReplicatedStorage:FindFirstChild("HiddenRegions")
        local Gameplay = workspace:FindFirstChild("Gameplay")
        local RegionsLoaded = Gameplay and Gameplay:FindFirstChild("RegionsLoaded")
        if HiddenRegions and RegionsLoaded then
            for _, hiddenRegion in pairs(HiddenRegions:GetChildren()) do
                if hiddenRegion.Parent ~= RegionsLoaded then
                    hiddenRegion.Parent = RegionsLoaded
                end
            end
        end
    end)
end

local function updateGlobalHitSpoof()
    local elementActive = false
    for elementName, levels in pairs(ElementZones) do
        for tier, _ in pairs(levels) do
            local flag = string.format("autoFarm%s%s", elementName, tier)
            if getgenv()[flag] then
                elementActive = true
                break
            end
        end
        if elementActive then break end
    end

    getgenv().globalHitSpoof =
        getgenv().autoTeleportToBoss
        or getgenv().autoWalkBossPremium
        or getgenv().autoBringBoss
        or getgenv().autoQuestExecute
        or elementActive
end

local function startMasterElementFarm()
    if getgenv().elementFarmLoopActive then return end
    getgenv().elementFarmLoopActive = true
    task.spawn(function()
        while getgenv().elementFarmLoopActive do
            local isAnyActive = false
            for elementName, levels in pairs(ElementZones) do
                for tier, _ in pairs(levels) do
                    if getgenv()[string.format("autoFarm%s%s", elementName, tier)] then
                        isAnyActive = true
                        break
                    end
                end
                if isAnyActive then break end
            end
            if not isAnyActive then
                getgenv().elementFarmLoopActive = false
                getgenv().manualElementCommitFolder = nil
                getgenv().manualElementCommitElement = nil
                getgenv().manualElementCommitTier = nil
                return
            end
            pcall(function()
                forceLoadZones()
                local char = Players.LocalPlayer.Character
                if not char then return end
                local charRoot = char:FindFirstChild("HumanoidRootPart")
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                if not charRoot or not humanoid then return end

                if getgenv().manualElementCommitFolder and getgenv().manualElementCommitFolder.Parent then
                    local commitFlag = string.format("autoFarm%s%s", getgenv().manualElementCommitElement, getgenv().manualElementCommitTier)
                    if not getgenv()[commitFlag] then
                        getgenv().manualElementCommitFolder = nil
                        getgenv().manualElementCommitElement = nil
                        getgenv().manualElementCommitTier = nil
                    else
                        local aliveEnemies = {}
                        for _, obj in ipairs(getgenv().manualElementCommitFolder:GetChildren()) do
                            local root = obj:FindFirstChild("HumanoidRootPart")
                            if root then
                                local healthAttr = obj:GetAttribute("Health")
                                if not healthAttr or healthAttr > 0 then
                                    table.insert(aliveEnemies, root)
                                end
                            end
                        end
                        if #aliveEnemies > 0 then
                            local zonePos = nil
                            local zoneCFrame = nil
                            if getgenv().manualElementCommitFolder:IsA("BasePart") then
                                zonePos = getgenv().manualElementCommitFolder.Position
                                zoneCFrame = getgenv().manualElementCommitFolder.CFrame + Vector3.new(0, 3, 0)
                            elseif getgenv().manualElementCommitFolder:IsA("Model") and getgenv().manualElementCommitFolder.PrimaryPart then
                                zonePos = getgenv().manualElementCommitFolder.PrimaryPart.Position
                                zoneCFrame = getgenv().manualElementCommitFolder.PrimaryPart.CFrame + Vector3.new(0, 3, 0)
                            end
                            if zonePos and zoneCFrame then
                                local horizontalDist = (Vector3.new(charRoot.Position.X, 0, charRoot.Position.Z) - Vector3.new(zonePos.X, 0, zonePos.Z)).Magnitude
                                if horizontalDist > 50 then
                                    charRoot.CFrame = zoneCFrame
                                end
                            end
                            local closestRoot = nil
                            local closestDist = math.huge
                            for _, root in ipairs(aliveEnemies) do
                                local d = (charRoot.Position - root.Position).Magnitude
                                if d < closestDist then
                                    closestDist = d
                                    closestRoot = root
                                end
                            end
                            if closestRoot then
                                if closestDist > 50 then
                                    charRoot.CFrame = closestRoot.CFrame + Vector3.new(0, 3, 0)
                                elseif closestDist > 8 then
                                    humanoid:MoveTo(closestRoot.Position)
                                else
                                    humanoid:MoveTo(charRoot.Position)
                                end
                            end
                            return
                        else
                            getgenv().manualElementCommitFolder = nil
                            getgenv().manualElementCommitElement = nil
                            getgenv().manualElementCommitTier = nil
                        end
                    end
                end

                local validZones = {}
                for elementName, levels in pairs(ElementZones) do
                    for tier, getter in pairs(levels) do
                        local flagName = string.format("autoFarm%s%s", elementName, tier)
                        if getgenv()[flagName] then
                            local ok, folder = pcall(getter)
                            if ok and folder then
                                local hasAlive = false
                                for _, obj in ipairs(folder:GetChildren()) do
                                    local root = obj:FindFirstChild("HumanoidRootPart")
                                    if root then
                                        local healthAttr = obj:GetAttribute("Health")
                                        if not healthAttr or healthAttr > 0 then hasAlive = true; break end
                                    end
                                end
                                if hasAlive then table.insert(validZones, {folder = folder, element = elementName, tier = tier}) end
                            end
                        end
                    end
                end
                if #validZones > 0 then
                    local selectedZone = validZones[math.random(1, #validZones)]
                    getgenv().manualElementCommitFolder = selectedZone.folder
                    getgenv().manualElementCommitElement = selectedZone.element
                    getgenv().manualElementCommitTier = selectedZone.tier
                    local folder = selectedZone.folder
                    local zoneCFrame = nil
                    if folder:IsA("BasePart") then zoneCFrame = folder.CFrame + Vector3.new(0, 3, 0)
                    elseif folder:IsA("Model") and folder.PrimaryPart then zoneCFrame = folder.PrimaryPart.CFrame + Vector3.new(0, 3, 0) end
                    if zoneCFrame then
                        charRoot.CFrame = zoneCFrame
                        task.wait(0.1)
                    end
                end
            end)
            task.wait(0.1)
        end
    end)
end

