local function GetEggPriority(imageId)
    for tierName, tierData in pairs(EggPriorities) do
        for _, id in pairs(tierData.ids) do
            if imageId == id then
                return tierData.priority, tierName
            end
        end
    end
    return 0, "UNKNOWN"
end

