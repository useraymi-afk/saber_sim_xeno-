getgenv().autoInvisible = false
getgenv().invisCache = {}

function toggleInvisibility(state)
    getgenv().autoInvisible = state
    if state then
        spawn(function()
            qprint("Invisibility Enabled (Combat Safe)")
            while getgenv().autoInvisible do
                local char = Players.LocalPlayer.Character
                if char then
                    for _, obj in pairs(char:GetDescendants()) do
                        if obj:IsA("BasePart") or obj:IsA("Decal") or obj:IsA("Texture") then
                            if not getgenv().invisCache[obj] then
                                getgenv().invisCache[obj] = obj.Transparency
                            end
                            obj.Transparency = 1
                        end
                    end
                    local head = char:FindFirstChild("Head")
                    if head then
                        local face = head:FindFirstChild("face")
                        if face and not getgenv().invisCache[face] then
                            getgenv().invisCache[face] = face.Transparency
                            face.Transparency = 1
                        end
                    end
                end
                task.wait(0.1)
            end
        end)
    else
        qprint("Invisibility Disabled")
        for obj, originalTransparency in pairs(getgenv().invisCache) do
            if obj and obj.Parent then
                obj.Transparency = originalTransparency
            end
        end
        getgenv().invisCache = {}
    end
end

