                        -- FORCE STOP Dungeon/Egg automation the moment a quest completes so we don't get stuck!
                        stopQuestDungeonAutomation()
                        stopQuestEggAutomation()

                        getgenv().questCommitment = nil
                        getgenv().questCommitmentIds = {}
                        getgenv().flagCooldownUntil = 0
                        getgenv().bossQuestHitTime = 0
                        getgenv().bossQuestHitId = nil

                        -- Wait slightly longer for server to register the claim and give new quests
                        task.wait(1.5)
                        return
                    end
                end

                -- 2. Scan all available quests
                local activeQuests = {
                    element = false,
                    elementboss = false,
                    boss = false,
                    egg = false,
                    dungeon = false,
                    koth = false,
                    flag = false
                }

                local hardestDungeonDifficulty = 0

                for questIndex, q in pairs(quests) do
                    local cfg = QuestInfo.ClanQuests[q.Id]

                    if cfg and q.Amount < cfg.GoalAmount then
                        local typeCfg = QuestInfo.QuestTypes[cfg.QuestType]
                        local text = ""

                        if typeCfg then
                            local ok, txt = pcall(function()
                                return typeCfg.InfoText(q.Amount, cfg.GoalAmount, cfg)
                            end)
                            if ok and txt then
                                text = tostring(txt):lower()
                            else
                                text = tostring(cfg.QuestType):lower()
                            end
                        end

                        local detectedType = nil
                        if text:find("element") and text:find("boss") then detectedType = "elementboss"
                        elseif text:find("fire") or text:find("water") or text:find("earth") or text:find("plasma") or text:find("element") then detectedType = "element"
                        elseif text:find("boss") then detectedType = "boss"
                        elseif text:find("egg") or text:find("hatch") then detectedType = "egg"
                        elseif text:find("dungeon") then detectedType = "dungeon"
                        elseif text:find("koth") or text:find("king of the hill") then detectedType = "koth"
                        elseif text:find("flag") then detectedType = "flag"
                        end

                        if detectedType then
                            local skip = false
                            if detectedType == "element" and getgenv().skipElementQuest then skip = true end
                            if detectedType == "elementboss" and getgenv().skipElementQuest then skip = true end
                            if detectedType == "boss" and getgenv().skipBossQuest then skip = true end
                            if detectedType == "egg" and getgenv().skipEggQuest then skip = true end
                            if detectedType == "dungeon" and getgenv().skipDungeonQuest then skip = true end
                            if detectedType == "koth" and getgenv().skipKOTHQuest then skip = true end
                            if detectedType == "flag" and getgenv().skipFlagQuest then skip = true end

                            if detectedType == "flag" and tick() < getgenv().flagCooldownUntil then skip = true end

                            if detectedType == "dungeon" then
                                local cooldownEnd = ClientDataManager.Data and ClientDataManager.Data.DungeonCooldownEndDT or 0
                                if DateTimeManager:Now() < cooldownEnd then skip = true end

                                local diff = 1
                                if text:find("impossible") then diff = 4
                                elseif text:find("hard") then diff = 3
                                elseif text:find("medium") then diff = 2
                                end
                                if diff > hardestDungeonDifficulty then
                                    hardestDungeonDifficulty = diff
                                end
                            end

                            if detectedType == "boss" and getgenv().bossQuestHitId == q.Id and (tick() - getgenv().bossQuestHitTime >= 5) then
                                skip = true
                            end

                            if not skip then
                                activeQuests[detectedType] = true
                            end
                        end
                    end
                end

                -- 3. Commitment Logic
                if getgenv().questCommitment == "dungeon" then
                    local shouldBreak = false
                    if getgenv().skipDungeonQuest then shouldBreak = true end

                    local cooldownEnd = ClientDataManager.Data and ClientDataManager.Data.DungeonCooldownEndDT or 0
                    if DateTimeManager:Now() < cooldownEnd then shouldBreak = true end

                    local anyDungeonActive = false
                    for _, q in pairs(quests) do
                        local cfg = QuestInfo.ClanQuests[q.Id]
                        if cfg and q.Amount < cfg.GoalAmount then
                            local typeCfg = QuestInfo.QuestTypes[cfg.QuestType]
                            if typeCfg then
                                local ok, txt = pcall(function() return typeCfg.InfoText(q.Amount, cfg.GoalAmount, cfg) end)
                                if ok and txt and tostring(txt):lower():find("dungeon") then
                                    anyDungeonActive = true
                                    break
                                end
                            end
                        end
                    end
                    if not anyDungeonActive then shouldBreak = true end

                    if shouldBreak then
                        qprint("Breaking dungeon commitment!")
                        getgenv().questCommitment = nil
                        getgenv().questCommitmentIds = {}
                        stopQuestDungeonAutomation()
                    else
                        if not getgenv().autoFarmDungeon then
                            qprint("Dungeon commitment active, ensuring all Dungeon features are ON")
                            getgenv().autoJoinDungeon = true; autoJoinDungeon()
                            getgenv().autoFarmDungeon = true; autoFarmDungeon()
                            getgenv().autoDungeonRewards = true; autoCollectDungeonRewards()
                            getgenv().autoIncubateDungeonEgg = true; autoIncubateDungeonEgg()
                            getgenv().autoClaimIncubated = true; autoClaimIncubatedPet()
                        end
                        QuestFarmDungeon()
                        return
                    end

                elseif getgenv().questCommitment == "egg" then
                    local shouldBreak = false
                    if getgenv().skipEggQuest then shouldBreak = true end
                    local anyEggActive = false
                    for _, q in pairs(quests) do
                        local cfg = QuestInfo.ClanQuests[q.Id]
                        if cfg and q.Amount < cfg.GoalAmount then
                            local typeCfg = QuestInfo.QuestTypes[cfg.QuestType]
                            if typeCfg then
                                local ok, txt = pcall(function() return typeCfg.InfoText(q.Amount, cfg.GoalAmount, cfg) end)
                                if ok and txt and (tostring(txt):lower():find("egg") or tostring(txt):lower():find("hatch")) then
                                    anyEggActive = true
                                    break
                                end
                            end
                        end
                    end
                    if not anyEggActive then shouldBreak = true end
                    if shouldBreak then
                        qprint("Breaking egg commitment!")
                        getgenv().questCommitment = nil
                        getgenv().questCommitmentIds = {}
                        stopQuestEggAutomation()
                    else
                        return
                    end
                end

                -- 4. Intelligent Multitasking Combinations

                if activeQuests.boss and activeQuests.elementboss then
                    stopKothElementTimeShare()
                    stopQuestDungeonAutomation()
                    stopQuestEggAutomation()

                    if shouldFarmBoss() then
                        markBossQuestHit(quests, QuestInfo)
                        QuestFarmBossWalk()
                    else
                        FarmElementBossWithFallback()
                    end
                    return

                elseif activeQuests.boss and activeQuests.element then
                    stopKothElementTimeShare()
                    stopQuestDungeonAutomation()
                    stopQuestEggAutomation()

                    if shouldFarmBoss() then
                        markBossQuestHit(quests, QuestInfo)
                        QuestFarmBossWalk()
                    else
                        FarmAnyAvailableElement(false)
                    end
                    return

                elseif activeQuests.boss and activeQuests.koth then
                    stopKothElementTimeShare()
                    stopQuestDungeonAutomation()
                    stopQuestEggAutomation()

                    if shouldFarmBoss() then
                        markBossQuestHit(quests, QuestInfo)
                        QuestFarmBossWalk()
                    else
                        QuestFarmKOTH()
                    end
                    return

                elseif activeQuests.koth and activeQuests.element then
                    stopQuestDungeonAutomation()
                    stopQuestEggAutomation()
                    startKothElementTimeShare()
                    return

                elseif activeQuests.koth and activeQuests.elementboss then
                    stopQuestDungeonAutomation()
                    stopQuestEggAutomation()
                    startKothElementTimeShare()
                    return

                else
                    stopKothElementTimeShare()
                end

                -- 5. Single Quest Fallbacks

                if activeQuests.dungeon then
                    getgenv().questCommitment = "dungeon"
                    getgenv().questCommitmentIds = {}

                    for _, q in pairs(quests) do
                        local cfg = QuestInfo.ClanQuests[q.Id]
                        if cfg and q.Amount < cfg.GoalAmount then
                            local typeCfg = QuestInfo.QuestTypes[cfg.QuestType]
                            if typeCfg then
                                local ok, txt = pcall(function() return typeCfg.InfoText(q.Amount, cfg.GoalAmount, cfg) end)
                                if ok and txt and tostring(txt):lower():find("dungeon") then
                                    table.insert(getgenv().questCommitmentIds, q.Id)
                                end
                            end
                        end
                    end

                    if hardestDungeonDifficulty > 0 then
                        getgenv().SelectedDifficulty = hardestDungeonDifficulty
                        local diffNames = {[1] = "Easy", [2] = "Medium", [3] = "Hard", [4] = "Impossible"}
                        qprint("Hardest dungeon difficulty:", diffNames[hardestDungeonDifficulty] or hardestDungeonDifficulty)
                    end

                    stopQuestEggAutomation()
                    getgenv().autoJoinDungeon = true; autoJoinDungeon()
                    getgenv().autoFarmDungeon = true; autoFarmDungeon()
                    getgenv().autoDungeonRewards = true; autoCollectDungeonRewards()
                    getgenv().autoIncubateDungeonEgg = true; autoIncubateDungeonEgg()
                    getgenv().autoClaimIncubated = true; autoClaimIncubatedPet()
                    QuestFarmDungeon()

                elseif activeQuests.egg then
                    getgenv().questCommitment = "egg"
                    getgenv().questCommitmentIds = {}
                    for _, q in pairs(quests) do
                        local cfg = QuestInfo.ClanQuests[q.Id]
                        if cfg and q.Amount < cfg.GoalAmount then
                            local typeCfg = QuestInfo.QuestTypes[cfg.QuestType]
                            if typeCfg then
                                local ok, txt = pcall(function() return typeCfg.InfoText(q.Amount, cfg.GoalAmount, cfg) end)
                                if ok and txt and (tostring(txt):lower():find("egg") or tostring(txt):lower():find("hatch")) then
                                    table.insert(getgenv().questCommitmentIds, q.Id)
                                end
                            end
                        end
                    end
                    stopQuestDungeonAutomation()
                    startQuestEggAutomation()

                elseif activeQuests.flag then
                    stopQuestDungeonAutomation()
                    stopQuestEggAutomation()
                    QuestFarmFlags()

                elseif activeQuests.koth then
                    stopQuestDungeonAutomation()
                    stopQuestEggAutomation()
                    QuestFarmKOTH()

                elseif activeQuests.elementboss then
                    stopQuestDungeonAutomation()
                    stopQuestEggAutomation()
                    FarmElementBossWithFallback()

                elseif activeQuests.element then
                    stopQuestDungeonAutomation()
                    stopQuestEggAutomation()
                    FarmAnyAvailableElement(false)

                elseif activeQuests.boss then
                    stopQuestDungeonAutomation()
                    stopQuestEggAutomation()

                    if shouldFarmBoss() then
                        markBossQuestHit(quests, QuestInfo)
                        QuestFarmBossWalk()
                    else
                        qprint("Boss hit for 5s. Waiting for timer...")
                        task.wait(1)
                    end

                else
                    stopQuestDungeonAutomation()
                    stopQuestEggAutomation()
                    getgenv().currentFarmingFolder = nil
                    task.wait(1)
                end
            end)

            if not success then
                -- Only warn if it's NOT the Gameplay loading error (we expect that one during teleports)
                if not tostring(err):find("Gameplay is not a valid member") then
                    qwarn("Quest loop error:", err)
                end
            end

            task.wait(0.1)
        end

        -- Cleanup
        stopKothElementTimeShare()
        stopQuestDungeonAutomation()
        stopQuestEggAutomation()
        getgenv().currentFarmingFolder = nil
        getgenv().currentFarmingFlagBase = nil
        getgenv().questCommitment = nil
        getgenv().questCommitmentIds = {}
        getgenv().bossQuestHitTime = 0
        getgenv().bossQuestHitId = nil

        pcall(function()
            local char = Players.LocalPlayer.Character
            if char then
                local charRoot = char:FindFirstChild("HumanoidRootPart")
                if charRoot then charRoot.Anchored = false end
            end
        end)

        updateGlobalHitSpoof()
        qprint("Quest loop stopped")
    end)
end

