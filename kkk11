getgenv().kothElementTimeShareActive = false

function startKothElementTimeShare()
    if getgenv().kothElementTimeShareActive then return end
    getgenv().kothElementTimeShareActive = true
    task.spawn(function()
        qprint("KOTH/Element Time-Share: Started (Walk Mode)")
        local lp = Players.LocalPlayer
        while getgenv().kothElementTimeShareActive do
            pcall(function()
                local char = lp.Character
                if not char then return end
                local charRoot = char:FindFirstChild("HumanoidRootPart")
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                if not charRoot or not humanoid then return end
                forceLoadZones()
                -- PHASE 1: KOTH (2.1 Seconds)
                local koth = workspace.Gameplay:FindFirstChild("KOTH")
                if koth then
                    local boundary = koth:FindFirstChild("KOH_BOUNDARY")
                    if boundary then
                        local ring = boundary:FindFirstChild("Meshes/ring") or boundary:FindFirstChild("ring") or boundary:FindFirstChildWhichIsA("BasePart")
                        if ring then
                            charRoot.CFrame = ring.CFrame + Vector3.new(0, 3, 0)
                            charRoot.Anchored = true
                            charRoot.AssemblyLinearVelocity = Vector3.zero
                            task.wait(3)
                        end
                    end
                end
                -- PHASE 2: ELEMENT FARM (2.5 Seconds) - Walk to mobs
                charRoot.Anchored = false
                local bestZone = nil
                local aliveMobs = {}
                for zoneName, zoneCFrame in pairs(ZoneCenters) do
                    local zoneMobs = {}
                    for _, mob in pairs(CollectionService:GetTagged("Mob")) do
                        if (mob:GetAttribute("Health") or 0) > 0 then
                            local mobRoot = mob:FindFirstChild("HumanoidRootPart")
                            if mobRoot and (mobRoot.Position - zoneCFrame.Position).Magnitude < 250 then
                                table.insert(zoneMobs, mob)
                            end
                        end
                    end
                    if #zoneMobs > #aliveMobs then
                        aliveMobs = zoneMobs
                        bestZone = zoneCFrame
                    end
                end
                if bestZone and #aliveMobs > 0 then
                    local horizontalDist = (Vector3.new(charRoot.Position.X, 0, charRoot.Position.Z) - Vector3.new(bestZone.Position.X, 0, bestZone.Position.Z)).Magnitude
                    if horizontalDist > 50 then
                        charRoot.CFrame = bestZone
                    end
                    local closestRoot = nil
                    local closestDist = math.huge
                    for _, mob in ipairs(aliveMobs) do
                        local mobRoot = mob:FindFirstChild("HumanoidRootPart")
                        if mobRoot then
                            local d = (charRoot.Position - mobRoot.Position).Magnitude
                            if d < closestDist then
                                closestDist = d
                                closestRoot = mobRoot
                            end
                        end
                    end
                    if closestRoot then
                        if closestDist > 50 then
                            charRoot.CFrame = closestRoot.CFrame + Vector3.new(0, 3, 0)
                        elseif closestDist > 8 then
                            humanoid:MoveTo(closestRoot.Position)
                        else
                            humanoid:MoveTo(charRoot.Position)
                        end
                    end
                    task.wait(3)
                else
                    task.wait(1)
                end
            end)
            task.wait(0.1)
        end
        pcall(function()
            local char = lp.Character
            if char then
                local charRoot = char:FindFirstChild("HumanoidRootPart")
                if charRoot then charRoot.Anchored = false end
            end
        end)
        qprint("KOTH/Element Time-Share: Stopped")
    end)
end

function stopKothElementTimeShare()
    getgenv().kothElementTimeShareActive = false
end

